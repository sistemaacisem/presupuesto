# ═══════════════════════════════════════════════════════════════
# Asistente de Compras Inteligente — Variables de Entorno
# ═══════════════════════════════════════════════════════════════
# INSTRUCCIONES PARA PRODUCCIÓN:
#   1. Copiar este archivo a .env
#   2. GENERAR UN NUEVO JWT_SECRET (ver abajo)
#   3. ROTAR LA CONTRASEÑA DE SUPABASE ANTES DE USAR
#   4. Poner NODE_ENV=production
#   5. Configurar CADDY_DOMAIN y CADDY_EMAIL para SSL
# ═══════════════════════════════════════════════════════════════

# Puerto del servidor
PORT=3000

# Driver de base de datos: sqlite (local) o pg (Supabase/PostgreSQL)
DB_DRIVER=pg

# ─── PostgreSQL / Supabase ───────────────────────────────────────
# ⚠ IMPORTANTE: Rotar esta contraseña en Supabase antes de usar.
#   Ve a: Supabase → Project Settings → Database → Reset database password
#   LUEGO actualizá DATABASE_URL con la nueva contraseña.
# La URL actual (con credenciales viejas) está filtrada por .gitignore
# pero ya se commiteó en el historial temprano del repo.
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres

# ─── JWT ──────────────────────────────────────────────────────────
# Generar una nueva clave en producción (NUNCA usar la misma que dev):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambiar_por_un_seguro_generado_con_crypto_randomBytes
JWT_EXPIRES_IN=24h

# ─── Entorno ──────────────────────────────────────────────────────
# development → SQLite local, SSL relajado
# production  → PostgreSQL, SSL estricto, Vite build
NODE_ENV=development

# ─── Docker / Infra ───────────────────────────────────────────────
PG_PASSWORD=
CADDY_DOMAIN=
CADDY_EMAIL=

# ─── Error Tracking (opcional) ────────────────────────────────────
# Configurar en https://sentry.io para capturar errores 5xx en prod
SENTRY_DSN=
SENTRY_SAMPLE_RATE=0.1

# ─── Seed ─────────────────────────────────────────────────────────
# Poner false en producción para no insertar datos demo
SEED_DEMO=false
