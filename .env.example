# Asistente de Compras Inteligente — Variables de Entorno

# Puerto del servidor
PORT=3000

# Driver de base de datos: sqlite (local) o pg (Supabase/PostgreSQL)
DB_DRIVER=sqlite

# Conexión a PostgreSQL (obligatorio si DB_DRIVER=pg)
# Se obtiene de Supabase → Project Settings → Database → Connection string
# IMPORTANTE: Rotar esta contraseña en producción
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres

# Clave secreta para JWT (generar una nueva en producción)
#   Linux/Mac: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   Windows:   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# En Docker se genera automáticamente si no se provee
JWT_SECRET=cambiar_por_un_seguro_generado_con_crypto_randomBytes

# Expiración del token JWT
JWT_EXPIRES_IN=24h

# Entorno (development / production)
# En producción SSL se habilita automáticamente (rejectUnauthorized: true)
NODE_ENV=development

# Contraseña de PostgreSQL para Docker (solo docker-compose)
# Si no se define, se usa: presupuesto_secret
PG_PASSWORD=

# Dominio público para HTTPS con Let's Encrypt (solo docker-compose)
# Dejar vacío para desarrollo local (HTTP sin cifrar)
# Ejemplo: CADDY_DOMAIN=presupuesto.midominio.com
CADDY_DOMAIN=

# Email para el registro de Let's Encrypt (solo docker-compose)
# Obligatorio si CADDY_DOMAIN está definido
# Ejemplo: CADDY_EMAIL=admin@midominio.com
CADDY_EMAIL=

# DSN de Sentry para error tracking (opcional)
# Obtener de https://sentry.io o self-hosted Sentry
# Ejemplo: SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxx.ingest.sentry.io/xxxxxx
SENTRY_DSN=

# Tasa de muestreo para Sentry (0.0 a 1.0, por defecto 0.1)
SENTRY_SAMPLE_RATE=0.1

# Sembrar datos demo al iniciar (solo Docker, DB_DRIVER=pg)
# true  → inserta datos demo si la tabla budgets está vacía
# false → no inserta nada, ideal para producción
SEED_DEMO=true
